# ============================================================
# AI Drug Discovery Platform
# Professional .gitignore
# ============================================================

# ------------------------------------------------------------
# Python
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# ------------------------------------------------------------
# Virtual Environments
# ------------------------------------------------------------
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# ------------------------------------------------------------
# Environment Variables
# ------------------------------------------------------------
.env
.env.*
!.env.example

# ------------------------------------------------------------
# Streamlit
# ------------------------------------------------------------
.streamlit/secrets.toml

# ------------------------------------------------------------
# IDE
# ------------------------------------------------------------
.vscode/
.idea/

# ------------------------------------------------------------
# VS Code Test
# ------------------------------------------------------------
.vscode-test/

# ------------------------------------------------------------
# macOS
# ------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride

# ------------------------------------------------------------
# Windows
# ------------------------------------------------------------
Thumbs.db
Desktop.ini

# ------------------------------------------------------------
# Linux
# ------------------------------------------------------------
*~

# ------------------------------------------------------------
# Logs
# ------------------------------------------------------------
*.log
logs/
log/

# ------------------------------------------------------------
# Build
# ------------------------------------------------------------
build/
dist/
site/
pip-wheel-metadata/
*.egg-info/
.eggs/

# ------------------------------------------------------------
# Python Cache
# ------------------------------------------------------------
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.cache/
.coverage
.coverage.*
htmlcov/

# ------------------------------------------------------------
# Jupyter
# ------------------------------------------------------------
.ipynb_checkpoints/

# ------------------------------------------------------------
# Generated Reports
# ------------------------------------------------------------
exports/
reports/
results/
output/
outputs/
generated/

# ------------------------------------------------------------
# Docking Files
# ------------------------------------------------------------
*.pdb
*.pdbqt
*.mol2
*.mol
*.sdf
*.xyz
*.gro
*.trr
*.xtc
*.dcd

# ------------------------------------------------------------
# Temporary Files
# ------------------------------------------------------------
*.tmp
*.temp
*.bak
*.old
*.swp
*.swo

# ------------------------------------------------------------
# Archives
# ------------------------------------------------------------
*.zip
*.rar
*.7z
*.tar
*.gz

# ------------------------------------------------------------
# Compiled Libraries
# ------------------------------------------------------------
*.dll
*.so
*.dylib

# ------------------------------------------------------------
# Node
# ------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ------------------------------------------------------------
# Local Databases
# ------------------------------------------------------------
*.sqlite
*.sqlite3
*.db

# ------------------------------------------------------------
# API Keys
# ------------------------------------------------------------
apikey.txt
keys.json
credentials.json
client_secret.json
service_account.json

# ------------------------------------------------------------
# Google Credentials
# ------------------------------------------------------------
google_credentials.json

# ------------------------------------------------------------
# Package Managers
# ------------------------------------------------------------
poetry.lock
Pipfile.lock

# ------------------------------------------------------------
# Docker
# ------------------------------------------------------------
docker-compose.override.yml

# ------------------------------------------------------------
# GitHub Codespaces
# ------------------------------------------------------------
.codespaces/

# ------------------------------------------------------------
# Local Test Files
# ------------------------------------------------------------
test_output/
sandbox/
scratch/

# ------------------------------------------------------------
# Optional Generated Files
# Uncomment if your app generates these automatically
# ------------------------------------------------------------
# *.pdf
# *.csv
# *.png
# *.jpg
# *.jpeg

# ------------------------------------------------------------
# Keep These
# ------------------------------------------------------------
!README.md
!LICENSE
!requirements.txt
!packages.txt
!app.py
!*.css
!*.js
!*.html
!*.json
!assets/**
