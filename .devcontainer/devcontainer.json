{
  "name": "AI Drug Discovery Platform",

  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bookworm",

  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },

  "customizations": {
    "codespaces": {
      "openFiles": [
        "README.md",
        "app.py"
      ]
    },

    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.analysis.typeCheckingMode": "basic",
        "editor.formatOnSave": true,
        "editor.tabSize": 4,
        "editor.wordWrap": "on",
        "files.autoSave": "afterDelay",
        "terminal.integrated.defaultProfile.linux": "bash"
      },

      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-toolsai.jupyter",
        "ms-python.black-formatter",
        "charliermarsh.ruff",
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "eamodio.gitlens",
        "streetsidesoftware.code-spell-checker"
      ]
    }
  },

  "updateContentCommand": "if [ -f packages.txt ]; then sudo apt-get update && sudo xargs -a packages.txt apt-get install -y; fi && python -m pip install --upgrade pip && if [ -f requirements.txt ]; then pip install -r requirements.txt; fi && pip install streamlit && echo '========================================' && echo '✅ AI Drug Discovery Environment Ready' && echo '========================================'",

  "postAttachCommand": {
    "server": "streamlit run app.py --server.port=8501 --server.address=0.0.0.0 --server.headless=true --server.enableCORS=false --server.enableXsrfProtection=false"
  },

  "forwardPorts": [
    8501
  ],

  "portsAttributes": {
    "8501": {
      "label": "AI Drug Discovery Platform",
      "onAutoForward": "openPreview"
    }
  },

  "remoteUser": "vscode"
}
